# Tidyyy Configuration Example

# Comma-separated folders to watch
WATCH_DIRS=/Users/dubeysmac/Developer/Go/tidy-app/Tidyyy/tmp

# Poppler and Tesseract binaries (optional, leave empty if in PATH)
POPPLER_BIN=
TESSERACT_BIN=

# Llama CLI binary path
LLAMA_CLI_PATH=llama-cli

# Path to GGUF model
MODEL_PATH=gemma-3-270m-it-Q8_0.gguf

# Command timeout in seconds
TIMEOUT_SEC=25

# Maximum PDF pages to extract for context
PDF_PAGE_LIMIT=10

# Triage queue depth
QUEUE_DEPTH=64

# Cloud fallback and configuration
CLOUD_ENABLED=false
CLOUD_BASE_URL=
CLOUD_API_KEY=
CLOUD_MODEL=

# Skip renaming instead of using heuristic fallback when model output is invalid
SKIP_RENAME_ON_INVALID=true

# RAM Log configuration
RAM_LOG_FILE=./logs/ram_usage.txt
RAM_LOG_INTERVAL_SEC=2

# For F03 test runner
# FILE_PATH=
# MAX_OCR_MB=20
